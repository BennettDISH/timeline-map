# Database
DATABASE_URL=postgresql://username:password@localhost:5432/fantasy_map_timeline

# JWT Secret (generate a secure random string)
JWT_SECRET=your-super-secret-jwt-key-here

# Environment
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# SSO (server-side). Set all three to enable "Sign in with bennettdishman.com".
# The OAuth flow is built entirely server-side — there are NO VITE_ client vars anymore.
# Optionally set APP_BASE_URL to force an exact redirect_uri; otherwise the request origin is used.
AUTH_SERVICE_URL=
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
# APP_BASE_URL=https://your-app.example.com

# File upload settings
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp

# Railway specific (these will be auto-set by Railway)
PORT=3001